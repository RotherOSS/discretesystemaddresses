# filter test
my @Tests = (
    # No customer assignable and original mail is a new ticket
    # = new ticket (original) + new support data view ticket linked together
    {
        Name        => 'Original ticket as new, support data view ticket as new, both linked',
        From        => 'From: Customer <test@example-' . $Helper->GetRandomID() . '.com>',
        To          => 'To: Agent <agent@example.com>',
        Subject     => 'Subject: supp package test v1',
        TicketCheck => 1,
    },
    # No customer assignable and original mail is a follow-up
    # = new support data view ticket + follow-up ticket (original) linked together
    {
        Name        => 'Original ticket as follow-up, support data view ticket as new, both linked',
        From        => 'From: Customer <test@example-' . $Helper->GetRandomID() . '.com>',
        To          => 'To: Agent <agent@example.com>',
        Subject     => 'Subject: Re: [Ticket#' . $TestTicketNumber . '] supp package test v2',
        TicketCheck => 2,
    },
    # Customer is relatable and original mail is a new ticket
    # = follow-up support data view ticket + new ticket (original) linked together
    {
        Name        => 'Original ticket as new, support data view ticket as follow-up, both linked',
        From        => 'From: Customer <' . $TicketCustomer . '>',
        To          => 'To: Agent <agent@example.com>',
        Subject     => 'Subject: supp package test v3',
        TicketCheck => 1,
    },
    # Customer is relatable and original mail is a follow-up ticket
    # = follow-up support data view ticket + follow-up ticket (original) linked together
    {
        Name        => 'Original ticket as follow-up, support data view ticket as follow-up, both linked',
        From        => 'From: Customer <' . $TicketCustomer . '>',
        To          => 'To: Agent <agent@example.com>',
        Subject     => 'Subject: Re: [Ticket#' . $TestTicketNumber . '] supp package test v4',
        TicketCheck => 2,
    },
    # Original mail is a new support bundle ticket (supportbundle@otobo.de)
    # = follow-up support data view ticket in the new support bundle ticket (original)
    {
        Name         => 'Original support bundle ticket as new, support data view ticket as follow-up in same original ticket',
        From         => 'From: Customer <test@example-' . $Helper->GetRandomID() . '.com>',
        To           => 'To: supportbundle@otobo.de',
        Subject      => 'Subject: Support::Bundle::Email',
        TicketCheck  => 1,
        TicketBundle => 1,
    },
);

# Add test ticket type
my $TicketType = 'SupportBundle-' . $Helper->GetRandomID();
$TypeObject->TypeAdd(
    Name    => $TicketType,
    ValidID => 1,
    UserID  => 1,
);

# Set test global language for mail
$Helper->ConfigSettingChange(
    Key   => 'DefaultLanguage',
    Value => "en",
);

# Set test ticket type for PostFilterModule
if ( ref $ConfigObject->Get('PostMaster::PostFilterModule') eq 'HASH' ) {
    my %FilterModule;
    my %Jobs = %{ $ConfigObject->Get('PostMaster::PostFilterModule') };
    $FilterModule{'000-DetectSupportPackage'} = $Jobs{'000-DetectSupportPackage'};
    $FilterModule{'000-DetectSupportPackage'}{TicketType} = $TicketType;
    $Helper->ConfigSettingChange(
        Valid => 1,
        Key   => 'PostMaster::PostFilterModule',
        Value => \%FilterModule,
    );
}

# Run tests
for my $Test (@Tests) {
    my @Return;
    {
        my $CommunicationLogObject = $Kernel::OM->Create(
            'Kernel::System::CommunicationLog',
            ObjectParams => {
                Transport => 'Email',
                Direction => 'Incoming',
            },
        );
        $CommunicationLogObject->ObjectLogStart( ObjectLogType => 'Message' );

        my $Email =  $Test->{From} . "\n" . $Test->{To} . "\n" . $Test->{Subject} . "\n" . $SPMail;
        my $PostMasterObject = Kernel::System::PostMaster->new(
            CommunicationLogObject => $CommunicationLogObject,
            Email                  => \$Email,
            Debug                  => 2,
        );

        @Return = $PostMasterObject->Run();

        $CommunicationLogObject->ObjectLogStop(
            ObjectLogType => 'Message',
            Status        => 'Successful',
        );
        $CommunicationLogObject->CommunicationStop(
            Status => 'Successful',
        );
    }
    $Self->True(
        $Return[1] || 0,
        "$Test->{Name} - ticket of original mail exist",
    );
    $Self->Is(
        $Return[0] || 0,
        $Test->{TicketCheck},
        "$Test->{Name} - article of original mail created",
    );

    my $NewTicketID = $Return[1];
    my $LinkedTicket = $LinkObject->LinkList(
        Object => 'Ticket',
        Key    => $NewTicketID,
        State  => 'Valid',
        UserID => 1,
    );
    my ($LinkedTicketID) = keys %{ $LinkedTicket->{Ticket}->{Normal}->{Source} };

    my $SPArticleIndex = 0;
    if ( $Test->{TicketBundle} ) {
        $SPArticleIndex = 1;
        $LinkedTicketID = $NewTicketID;
    }

    my %Ticket = $TicketObject->TicketGet(
        TicketID => $LinkedTicketID,
        UserID   => 1,
        Extended => 1,
    );
    $Self->Is(
        $Ticket{Type},
        $TicketType,
        "Support Data Ticket - type set",
    );

    my @Articles = $ArticleObject->ArticleList(
        TicketID => $LinkedTicketID,
    );
    my $ArticleBackend = $ArticleObject->BackendForArticle(
        TicketID  => $LinkedTicketID,
        ArticleID => $Articles[$SPArticleIndex]{ArticleID},
    );
    my %AttachmentIndex = $ArticleBackend->ArticleAttachmentIndex(
        ArticleID        => $Articles[$SPArticleIndex]{ArticleID},
        ExcludePlainText => 1,
        ExcludeHTMLBody  => 1,
        ExcludeInline    => 1,
    );
    my $AttachmentCount = keys %AttachmentIndex;
    $Self->Is(
        $AttachmentCount,
        6,
        "Support Data Ticket - article attachments added",
    );

    my %Article = $ArticleBackend->ArticleGet(
        TicketID  => $LinkedTicketID,
        ArticleID => $Articles[$SPArticleIndex]{ArticleID},
    );
    $Article{Body} =~ /(Support Data Collector)/g;
    my $DataHeader = $1;
    $Self->Is(
        $DataHeader,
        "Support Data Collector",
        "Support Data Ticket - article support data header exist",
    );
}

# cleanup is done by RestoreDatabase.

$Self->DoneTesting();
