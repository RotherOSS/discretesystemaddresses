<?xml version="1.0" encoding="utf-8"?>
<otobo_package version="1.0">
    <Name>DiscreteAddresses</Name>
    <Version>10.1.1</Version>
    <Framework>10.1.x</Framework>
    <Vendor>Rother OSS GmbH</Vendor>
    <URL>https://rother-oss.com/</URL>
    <License>GNU AFFERO GENERAL PUBLIC LICENSE Version 3, November 2007</License>
    <Description Lang="en">Treat addresses as separate entities, allowing to send emails from one to another, and treat incoming emails independently for each.</Description>
    <Description Lang="de">Es werden Adressen als separate Einheiten betrachtet, sodass E-Mails von einer zur anderen gesendet und eingehende E-Mails unabhängig voneinander behandelt werden können.</Description>
    <IntroInstall Type="pre" Lang="en" Title="Information"><![CDATA[<br><br> Thank you for choosing our package!<br>For more Information regarding our services check <br><br><div style="margin-left: 40px;"><a href="https://rother-oss.com/">https://rother-oss.com/</a></div><br><br>]]></IntroInstall>
    <IntroInstall Type="pre" Lang="de" Title="Information"><![CDATA[<br><br> Vielen Dank dass Sie sich f&uuml;r unser Paket entschieden haben!<br>F&uuml;r mehr Informationen zu unseren Diensleistungen besuchen Sie: <br><br><div style="margin-left: 40px;"><a href="https://rother-oss.com/">https://rother-oss.com/</a></div><br><br>]]></IntroInstall>
    <Filelist>
        <!-- Config -->
        <File Permission="644" Location="Kernel/Config/Files/XML/DiscreteAddresses.xml"/>
        <!-- Language -->
        <File Permission="644" Location="Kernel/Language/de_DiscreteAddresses.pm"/>
        <!-- System -->
        <File Permission="644" Location="Custom/Kernel/System/PostMaster.pm"/>
        <File Permission="644" Location="Custom/Kernel/System/SystemAddress.pm"/>
        <File Permission="644" Location="Custom/Kernel/System/Ticket/Article/Backend/Email.pm"/>
        <File Permission="644" Location="Kernel/System/AddressPool.pm"/>
        <File Permission="644" Location="Kernel/System/PostMaster/Filter/MatchMessageID.pm"/>
    </Filelist>
</otobo_package>
